   "source": [
    "def mediaT(T, n): \n",
    "    somatorio = 0\n",
    "    for i in range(n):\n",
    "        somatorio += T[i]\n",
    "\n",
    "    return somatorio / n\n",
    "\n",
    "def varT(T, n):\n",
    "    somatorio = 0\n",
    "    for i in range(n):\n",
    "        somatorio += (T[i] - mediaT(T, n) ** 2)\n",
    "    \n",
    "    return somatorio / n\n",
    "\n"
   ]
  }
 ],
